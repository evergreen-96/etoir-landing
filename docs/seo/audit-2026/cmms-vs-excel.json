    <script>
        // ===== Header scroll effect =====
        const header = document.querySelector('.header');
        window.addEventListener('scroll', () => {
            header.classList.toggle('scrolled', window.scrollY > 20);
        }, { passive: true });

        // ===== Mobile menu =====
        const mobileToggle = document.getElementById('mobileToggle');
        const nav = document.getElementById('nav');

        mobileToggle.addEventListener('click', () => {
            nav.classList.toggle('open');
            const isOpen = nav.classList.contains('open');
            mobileToggle.setAttribute('aria-expanded', isOpen);
        });

        // Close mobile nav on link click
        nav.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                nav.classList.remove('open');
                mobileToggle.setAttribute('aria-expanded', 'false');
            });
        });

        // ===== Scroll Animations =====
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px'
        });

        document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

        // ===== Animated Counters =====
        const counterObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    animateCounter(entry.target);
                    counterObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('[data-count]').forEach(el => counterObserver.observe(el));

        function animateCounter(el) {
            const target = parseInt(el.dataset.count);
            const suffix = el.dataset.suffix || '';
            const duration = 1500;
            const start = performance.now();

            function update(now) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const value = Math.round(eased * target);
                el.textContent = value + suffix;
                if (progress < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
        }

        // ===== Features Sticky Scroll =====
        (function () {
          var TABS  = 4;
          var STEP  = 300;
          var current = 0;
          var progFrac = 0;

          var wrapper = document.getElementById('fw-sticky-wrapper');
          var section = document.getElementById('features-section');
          var hint    = document.getElementById('fw-scroll-hint');

          if (!wrapper || !section) return;

          function setWrapperHeight() {
            var innerH = document.getElementById('fw-sticky-inner').offsetHeight;
            wrapper.style.height = (innerH + TABS * STEP) + 'px';
          }
          setWrapperHeight();
          window.addEventListener('resize', setWrapperHeight);

          function activate(idx, frac) {
            idx  = Math.max(0, Math.min(TABS - 1, idx));
            frac = Math.max(0, Math.min(1, frac));

            document.querySelectorAll('#features-section .fw-tab').forEach(function (t, i) {
              t.classList.toggle('active', i === idx);
              var ico = t.querySelector('.fw-tab-icon');
              ico.style.background = i === idx ? '#2563eb' : '';
              ico.style.color = i === idx ? '#fff' : '';
            });

            document.querySelectorAll('#features-section .fw-panel').forEach(function (p, i) {
              var nowActive = i === idx;
              if (!p.classList.contains('active') && nowActive) p.classList.add('active');
              else if (p.classList.contains('active') && !nowActive) p.classList.remove('active');
            });

            for (var i = 0; i < TABS; i++) {
              var bar = document.getElementById('fw-prog-' + i);
              if (!bar) continue;
              if (i < idx)        bar.style.height = '100%';
              else if (i === idx) bar.style.height = (frac * 100) + '%';
              else                bar.style.height = '0%';
            }

            current  = idx;
            progFrac = frac;

            if (hint) hint.style.opacity = (idx > 0 || frac > 0.05) ? '0' : '1';
          }

          function onScroll() {
            if (window.innerWidth <= 700) return;
            var sectionTop   = section.getBoundingClientRect().top + window.scrollY;
            var scrolledInto = window.scrollY - sectionTop;
            var headerH = 260;
            var delta   = scrolledInto - headerH;

            if (delta < 0) { activate(0, 0); return; }

            var totalScrollable = TABS * STEP;
            if (delta >= totalScrollable) { activate(TABS - 1, 1); return; }

            activate(Math.floor(delta / STEP), (delta % STEP) / STEP);
          }

          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();

          window.fwGoTo = function (idx) {
            if (window.innerWidth <= 700) {
              activate(idx, 1);
              return;
            }
            var sectionTop = section.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({ top: sectionTop + 260 + idx * STEP + 10, behavior: 'smooth' });
          };

          // Touch swipe on mobile
          var txStart = 0, tyStart = 0;
          var panel = document.querySelector('#features-section .fw-right');
          if (panel) {
            panel.addEventListener('touchstart', function(e) { txStart = e.touches[0].clientX; tyStart = e.touches[0].clientY; }, { passive: true });
            panel.addEventListener('touchend', function(e) {
              if (window.innerWidth > 700) return;
              var dx = e.changedTouches[0].clientX - txStart;
              var dy = e.changedTouches[0].clientY - tyStart;
              if (Math.abs(dx) < Math.abs(dy) || Math.abs(dx) < 40) return;
              if (dx < 0) fwGoTo(current + 1);
              else fwGoTo(current - 1);
            }, { passive: true });
          }
        })();


        // ===== Results Section Counters =====
        (function(){
          var done = false;
          function run(){
            if(done) return; done = true;
            document.querySelectorAll('#results-section .counter').forEach(function(el){
              var t = parseInt(el.dataset.target, 10), s = null, d = 1500;
              function step(ts){ if(!s) s=ts; var p=Math.min((ts-s)/d,1), e=1-Math.pow(1-p,3); el.textContent=Math.round(e*t); if(p<1) requestAnimationFrame(step); }
              setTimeout(function(){ requestAnimationFrame(step); }, 150);
            });
          }
          var sec = document.getElementById('results-section');
          if (sec) {
            var o = new IntersectionObserver(function(en){ en.forEach(function(e){ if(e.isIntersecting) run(); }); }, {threshold:.2});
            o.observe(sec);
          }
        })();

        // ===== FAQ Accordion =====
        document.querySelectorAll('.faq-question').forEach(question => {
            question.addEventListener('click', () => {
                const item = question.parentElement;
                const answer = item.querySelector('.faq-answer');
                const isOpen = item.classList.contains('open');

                // Close all
                document.querySelectorAll('.faq-item.open').forEach(openItem => {
                    openItem.classList.remove('open');
                    openItem.querySelector('.faq-answer').style.maxHeight = '0';
                    openItem.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
                });

                // Open clicked (if it was closed)
                if (!isOpen) {
                    item.classList.add('open');
                    answer.style.maxHeight = answer.scrollHeight + 'px';
                    question.setAttribute('aria-expanded', 'true');
                }
            });

            // Keyboard support
            question.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    question.click();
                }
            });
        });

        // ===== Contact Form =====
        const form = document.getElementById('contactForm');
        const formContent = document.getElementById('formContent');
        const formSuccess = document.getElementById('formSuccess');

        form.addEventListener('submit', (e) => {
            e.preventDefault();

            // Basic validation
            const required = form.querySelectorAll('[required]');
            let valid = true;

            required.forEach(input => {
                if (!input.value.trim()) {
                    input.style.borderColor = 'var(--danger)';
                    valid = false;
                } else {
                    input.style.borderColor = '';
                }
            });

            // Email check
            const email = form.querySelector('#email');
            if (email.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
                email.style.borderColor = 'var(--danger)';
                valid = false;
            }

            // Consent check
            const consentCheck = form.querySelector('#consentCheck');
            const consentDiv = document.getElementById('formConsent');
            if (!consentCheck.checked) {
                consentDiv.classList.add('error');
                valid = false;
            } else {
                consentDiv.classList.remove('error');
            }

            if (!valid) return;

            fetch('/api/responses/', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    name:      form.querySelector('#name').value.trim(),
                    company:   form.querySelector('#company').value.trim(),
                    email:     form.querySelector('#email').value.trim(),
                    phone:     form.querySelector('#phone').value.trim(),
                    position:  form.querySelector('#position').value.trim() || null,
                    comment:   form.querySelector('#comment').value.trim() || null,
                    consent_privacy:   true,
                    consent_marketing: form.querySelector('#marketingCheck').checked,
                }),
            })
            .then(r => r.ok ? Promise.resolve() : Promise.reject())
            .then(() => {
                formContent.style.display = 'none';
                formSuccess.classList.add('visible');
            })
            .catch(() => {
                alert('脨聻脩聢脨赂脨卤脨潞脨掳 脨驴脩聙脨赂 脨戮脩聜脨驴脩聙脨掳脨虏脨潞脨碌. 脨聼脨戮脨驴脩聙脨戮脨卤脩聝脨鹿脩聜脨碌 脨驴脨戮脨路脨露脨碌 脨赂脨禄脨赂 脨陆脨掳脨驴脨赂脩聢脨赂脩聜脨碌 脨陆脨掳脨录 脨陆脨掳脨驴脩聙脩聫脨录脩聝脩聨.');
            });
        });

        // Clear validation on input
        form.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('input', () => {
                input.style.borderColor = '';
            });
        });

        form.querySelector('#consentCheck').addEventListener('change', () => {
            document.getElementById('formConsent').classList.remove('error');
        });

        // ===== Mockup Bar Animation =====
        const mockupObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const bars = entry.target.querySelectorAll('.mockup-bar');
                    bars.forEach((bar, i) => {
                        const h = bar.style.height;
                        bar.style.height = '0%';
                        setTimeout(() => {
                            bar.style.height = h;
                        }, i * 100 + 200);
                    });
                    mockupObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.3 });

        const mockupBars = document.getElementById('mockupBars');
        if (mockupBars) mockupObserver.observe(mockupBars);
    </script>

