    <script>
    (function() {
      'use strict';

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // 芒聰聙芒聰聙 Helpers 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      const delay = ms => new Promise(r => setTimeout(r, ms));

      function show(id) {
        document.getElementById(id)?.classList.add('ai-chat-bubble--visible');
      }
      function hide(id) {
        document.getElementById(id)?.classList.remove('ai-chat-bubble--visible');
      }
      function hideAll() {
        ['ai-chat-msg-1','ai-chat-typing','ai-chat-reply-1',
         'ai-chat-msg-2','ai-chat-typing-2','ai-chat-reply-2'].forEach(hide);
      }

      // 芒聰聙芒聰聙 Card 1: Chat loop 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      async function runChatLoop() {
        while (true) {
          hideAll();
          await delay(400);
          show('ai-chat-msg-1');
          await delay(600);
          show('ai-chat-typing');
          await delay(900);
          hide('ai-chat-typing');
          show('ai-chat-reply-1');
          await delay(700);
          show('ai-chat-msg-2');
          await delay(600);
          show('ai-chat-typing-2');
          await delay(900);
          hide('ai-chat-typing-2');
          show('ai-chat-reply-2');
          await delay(2500);
        }
      }

      const chatCard = document.querySelector('#ai-features .ai-card:nth-child(1)');
      if (chatCard) {
        if (reducedMotion) {
          ['ai-chat-msg-1','ai-chat-reply-1','ai-chat-msg-2','ai-chat-reply-2'].forEach(show);
        } else {
          new IntersectionObserver((entries, obs) => {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              runChatLoop();
            }
          }, { threshold: 0.4 }).observe(chatCard);
        }
      }

      // 芒聰聙芒聰聙 Card 2: Task rows fly-in 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      const taskCard = document.querySelector('#ai-features .ai-card:nth-child(2)');
      if (taskCard) {
        if (reducedMotion) {
          taskCard.classList.add('is-visible');
        } else {
          new IntersectionObserver((entries, obs) => {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              taskCard.classList.add('is-visible');
            }
          }, { threshold: 0.1 }).observe(taskCard);
        }
      }

      // 芒聰聙芒聰聙 Card 3: Counter 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      function animateCounter(el) {
        const target = +el.dataset.target;
        const duration = 1200;
        const start = performance.now();
        function tick(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(target * ease);
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = target;
        }
        requestAnimationFrame(tick);
      }

      const reportCard = document.querySelector('#ai-features .ai-card:nth-child(3)');
      const counterEl = reportCard?.querySelector('.ai-counter');
      if (reportCard && counterEl) {
        if (reducedMotion) {
          counterEl.textContent = counterEl.dataset.target;
        } else {
          new IntersectionObserver((entries, obs) => {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              animateCounter(counterEl);
            }
          }, { threshold: 0.1 }).observe(reportCard);
        }
      }

      // 芒聰聙芒聰聙 IoT Button Section 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      const iotSection = document.getElementById('iot-section');
      if (iotSection) {
        const IOT_SCENARIOS = [
          { color:'#dc2626', bg:'rgba(220,38,38,0.1)',  badge:'脨聬脨聮脨聬脨聽脨聵脨炉',        title:'脨聬脨虏脨掳脩聙脨赂脨鹿脨陆脩聥脨鹿 脨戮脩聛脩聜脨掳脨陆脨戮脨虏 芒聙聰 脨陆脨掳脩聛脨戮脩聛 脨聺脨聹-2500'   },
          { color:'#d97706', bg:'rgba(245,158,11,0.1)', badge:'脨聼脨聲脨聽脨聲脨聯脨聽脨聲脨聮',      title:'脨聼脨碌脩聙脨碌脨鲁脩聙脨碌脨虏 脨麓脨虏脨赂脨鲁脨掳脩聜脨碌脨禄脩聫 芒聙聰 脨潞脨戮脨录脨驴脩聙脨碌脩聛脩聛脨戮脩聙 脨職-3' },
          { color:'#9333ea', bg:'rgba(168,85,247,0.1)', badge:'脨聮脨聵脨聭脨聽脨聬脨娄脨聵脨炉',      title:'脨職脩聙脨赂脩聜脨赂脩聡脨碌脩聛脨潞脨掳脩聫 脨虏脨赂脨卤脩聙脨掳脩聠脨赂脩聫 芒聙聰 脩聙脨碌脨麓脩聝脨潞脩聜脨戮脩聙 脨聽-1' },
          { color:'#dc2626', bg:'rgba(220,38,38,0.1)',  badge:'脨拢脨垄脨聲脨搂脨職脨聬',        title:'脨拢脩聜脨碌脩聡脨潞脨掳 脨录脨掳脩聛脨禄脨掳 芒聙聰 脨鲁脨赂脨麓脩聙脨戮脩聛脩聜脨掳脨陆脩聠脨赂脩聫 脨聯脨隆-200'  },
          { color:'#d97706', bg:'rgba(245,158,11,0.1)', badge:'脨聻脨隆脨垄脨聬脨聺脨聻脨聮脨職脨聬',     title:'脨聮脨陆脨碌脨路脨掳脨驴脨陆脨掳脩聫 脨戮脩聛脩聜脨掳脨陆脨戮脨虏脨潞脨掳 芒聙聰 脨禄脨赂脨陆脨赂脩聫 芒聞聳2'        },
          { color:'#0891b2', bg:'rgba(6,182,212,0.1)',  badge:'脨聺脨聲脨聵脨隆脨聼脨聽脨聬脨聮脨聺脨聻脨隆脨垄脨卢', title:'脨隆脨卤脨戮脨鹿 脨驴脩聙脨赂脨虏脨戮脨麓脨掳 芒聙聰 脩聜脨戮脨潞脨掳脩聙脨陆脩聥脨鹿 脨垄脨隆-500'      },
        ];

        const iotTags      = Array.from(iotSection.querySelectorAll('.iot-tag'));
        const iotCap       = iotSection.querySelector('.iot-button-cap');
        const iotArrowLine = iotSection.querySelector('.iot-arrow-line');
        const iotDot       = document.getElementById('iot-card-dot');
        const iotBadge     = document.getElementById('iot-card-badge');
        const iotTitle     = document.getElementById('iot-card-title');
        const iotCard      = iotSection.querySelector('.iot-card');
        let iotCurrent     = 0;
        let iotCycleTimer  = null;

        function iotSetCard(idx) {
          const s = IOT_SCENARIOS[idx];
          iotDot.style.background   = s.color;
          iotBadge.textContent      = s.badge;
          iotBadge.style.background = s.bg;
          iotBadge.style.color      = s.color;
          iotTitle.textContent      = s.title;
        }

        function iotAnimateCard(idx) {
          iotCard.style.transition = 'opacity 0.2s ease';
          iotCard.style.opacity    = '0';
          setTimeout(() => {
            iotSetCard(idx);
            iotCard.style.transition = '';
            iotCard.style.opacity    = '';
            iotCard.style.animation  = 'none';
            iotCard.offsetHeight;         // force reflow to restart animation
            iotCard.style.animation  = 'iot-card-appear 0.4s ease forwards';
          }, 200);
        }

        function iotFireDot() {
          iotArrowLine.classList.remove('iot-arrow-line--firing');
          void iotArrowLine.offsetWidth;  // force reflow so animation restarts
          iotArrowLine.classList.add('iot-arrow-line--firing');
        }

        // Strict sequential cycle: tag 芒聠聮 press 芒聠聮 dot 芒聠聮 card 芒聠聮 pause 芒聠聮 next tag 芒聠聮 芒聙娄
        function iotRunCycle() {
          const prev = iotCurrent;
          iotCurrent = (iotCurrent + 1) % IOT_SCENARIOS.length;

          // Step 1: hide previous tag
          iotTags[prev].classList.remove('iot-tag--visible');

          // Step 2: show new tag 300ms later
          iotCycleTimer = setTimeout(() => {
            iotTags[iotCurrent].classList.add('iot-tag--visible');

            // Step 3: press button 900ms after tag appears
            iotCycleTimer = setTimeout(() => {
              iotCap.classList.add('iot-pressed');
              setTimeout(() => iotCap.classList.remove('iot-pressed'), 320);

              // Step 4: dot flies 150ms after press starts
              setTimeout(iotFireDot, 150);

              // Step 5: card updates when dot arrives (~700ms)
              setTimeout(() => iotAnimateCard(iotCurrent), 700);

              // Step 6: pause, then repeat
              iotCycleTimer = setTimeout(iotRunCycle, 2200);
            }, 900);
          }, 300);
        }

        if (reducedMotion) {
          iotTags[0].classList.add('iot-tag--visible');
          iotSetCard(0);
        } else {
          new IntersectionObserver((entries, obs) => {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              iotTags[0].classList.add('iot-tag--visible');
              iotSetCard(0);
              setTimeout(iotRunCycle, 1500);
            }
          }, { threshold: 0.3 }).observe(iotSection);
        }
      }

      // 芒聰聙芒聰聙 Floormap Section 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
      const fmapSection = document.getElementById('floormap-section');
      if (fmapSection) {
        const FMAP_SCENARIOS = [
          { machineIdx: 1, state: 'alarm', title: '脨聬脨虏脨掳脩聙脨赂脩聫',      sub: '脨陇脨聽-2 脗路 脨聬脨虏脨掳脩聙脨赂脨鹿脨陆脩聥脨鹿 脨戮脩聛脩聜脨掳脨陆脨戮脨虏',    dotColor: '#ef4444', borderColor: '#fecaca' },
          { machineIdx: 4, state: 'maint', title: '脨聼脨禄脨掳脨陆脨戮脨虏脨戮脨碌 脨垄脨聻', sub: '脨隆脨聮-2 脗路 脨垄脨碌脩聟脨陆脨赂脩聡脨碌脩聛脨潞脨戮脨碌 脨戮脨卤脩聛脨禄脩聝脨露脨赂脨虏脨掳脨陆脨赂脨碌', dotColor: '#f59e0b', borderColor: '#fde68a' },
          { machineIdx: 0, state: 'alarm', title: '脨聬脨虏脨掳脩聙脨赂脩聫',      sub: '脨垄脨聮-1 脗路 脨聼脨碌脩聙脨碌脨鲁脩聙脨碌脨虏 脨麓脨虏脨赂脨鲁脨掳脩聜脨碌脨禄脩聫',   dotColor: '#ef4444', borderColor: '#fecaca' },
          { machineIdx: 3, state: 'maint', title: '脨聼脨禄脨掳脨陆脨戮脨虏脨戮脨碌 脨垄脨聻', sub: '脨聺脨聹-1 脗路 脨聴脨掳脨录脨碌脨陆脨掳 脩聙脨掳脩聛脩聟脨戮脨麓脨陆脨赂脨潞脨戮脨虏',   dotColor: '#f59e0b', borderColor: '#fde68a' },
        ];

        const fmapMachines   = Array.from(fmapSection.querySelectorAll('.fmap-machine'));
        const fmapAlertCard  = document.getElementById('fmap-alert-card');
        const fmapAlertDot   = document.getElementById('fmap-alert-dot');
        const fmapAlertTitle = document.getElementById('fmap-alert-title');
        const fmapAlertSub   = document.getElementById('fmap-alert-sub');
        let fmapCurrent      = -1;
        let fmapTimer        = null;

        function fmapResetMachine(idx) {
          fmapMachines[idx].classList.remove('fmap-machine--alarm', 'fmap-machine--maint');
        }

        function fmapRunCycle() {
          const prevIdx = fmapCurrent >= 0 ? FMAP_SCENARIOS[fmapCurrent].machineIdx : -1;

          fmapCurrent = (fmapCurrent + 1) % FMAP_SCENARIOS.length;
          const s = FMAP_SCENARIOS[fmapCurrent];

          // Hide card, reset previous machine
          fmapAlertCard.classList.remove('fmap-alert-card--visible');
          fmapTimer = setTimeout(() => {
            if (prevIdx >= 0) fmapResetMachine(prevIdx);

            // Activate new machine
            fmapMachines[s.machineIdx].classList.add(
              s.state === 'alarm' ? 'fmap-machine--alarm' : 'fmap-machine--maint'
            );

            // Update card
            fmapAlertTitle.textContent   = s.title;
            fmapAlertSub.textContent     = s.sub;
            fmapAlertDot.style.background = s.dotColor;
            fmapAlertCard.style.borderColor = s.borderColor;

            // Show card
            fmapTimer = setTimeout(() => {
              fmapAlertCard.classList.add('fmap-alert-card--visible');
              fmapTimer = setTimeout(fmapRunCycle, 3000);
            }, 450);
          }, 350);
        }

        if (reducedMotion) {
          fmapMachines[1].classList.add('fmap-machine--alarm');
          fmapMachines[3].classList.add('fmap-machine--maint');
          fmapAlertTitle.textContent = '脨聬脨虏脨掳脩聙脨赂脩聫';
          fmapAlertSub.textContent   = '脨陇脨聽-2 脗路 脨聬脨虏脨掳脩聙脨赂脨鹿脨陆脩聥脨鹿 脨戮脩聛脩聜脨掳脨陆脨戮脨虏';
          fmapAlertCard.classList.add('fmap-alert-card--visible');
        } else {
          new IntersectionObserver((entries, obs) => {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              fmapTimer = setTimeout(fmapRunCycle, 1200);
            }
          }, { threshold: 0.3 }).observe(fmapSection);
        }
      }

    })();
    </script>
</body>
</html>
